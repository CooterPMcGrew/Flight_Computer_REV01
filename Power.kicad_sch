	(text "Decoupling consistant with UG933\n"
		(exclude_from_sim no)
		(at 171.45 37.084 0)
		(effects
			(font
				(size 1.524 1.524)
			)
			(justify left bottom)
		)
		(uuid "5788f40d-9ea9-45e4-9fc8-055047d427a7")
	)
	(text "CCPLL is a 1.8V nominal supply that provides \npower to the three PS PLLs and additional\nanalog circuits. It can be powered separately \nor derived from the VCCPAUX supply. If powered\nby VCCPAUX, VCCPLL must be filtered through \na 120Ω @ 100 MHz, size 0603 ferrite bead and\na 10 µF or larger, size 0603 decoupling capacitor. \nIn both cases a 0.47 µF to 4.7 µF 0402\ncapacitor must be placed near the VCCPLL BGA via. "
		(exclude_from_sim no)
		(at 94.234 172.466 0)
		(effects
			(font
				(size 1.524 1.524)
			)
			(justify left bottom)
		)
		(uuid "d722c15a-3fac-4921-8d88-465af5beb9b4")
	)
	(text "VCCPINT is a 1.0V nominal supply that powers \nall of the PS internal logic circuits. This supply \ncan be combined with VCCINT if the system \ndoes not require the PL supply to be powered \ndown independent of the PS.\n\nSame with AUX"
		(exclude_from_sim no)
		(at 13.462 29.464 0)
		(effects
			(font
				(size 1.524 1.524)
			)
			(justify left bottom)
		)
		(uuid "ed10bbe1-f2b9-4b1d-a1c6-8a5ba913e30f")
	)
	(text "Sequencing: \nPINT (1.0v) then \nPAUX and PLL together (1.8v) then\nMIO (3v3) and DDR (1v35) then\nPOR"
		(exclude_from_sim no)
		(at 104.14 192.786 0)
		(effects
			(font
				(size 1.524 1.524)
			)
			(justify left bottom)
		)
		(uuid "fa0e9baf-aa66-4f3f-aaae-0c9aa554d156")
	)
	(text "VCCPLL Identical to ZC702"
		(exclude_from_sim no)
		(at 215.392 163.83 0)
		(effects
			(font
				(size 1.524 1.524)
			)
			(justify left bottom)
		)
		(uuid "fa69c477-81e5-4901-b0bb-840164487e54")
	)
