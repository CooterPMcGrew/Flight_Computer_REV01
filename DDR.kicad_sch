	(text "1066 Mb/s (533 MHz)\nShould be attainable by all \nspeed grades of Zynq\n"
		(exclude_from_sim no)
		(at 235.966 264.922 0)
		(effects
			(font
				(size 1.524 1.524)
			)
			(justify left bottom)
		)
		(uuid "03a483c6-702c-4cc6-86d7-d2ff4aacbfe1")
	)
	(text "DDR3L trace impedance:\n40ohm differential\n80ohm single"
		(exclude_from_sim no)
		(at 26.416 26.289 0)
		(effects
			(font
				(size 1.524 1.524)
			)
			(justify left bottom)
		)
		(uuid "2e94ce3d-5f61-4640-97ea-b7694eb31212")
	)
	(text "Terminations as described in UG933\nand shown in ZC702 schematic"
		(exclude_from_sim no)
		(at 259.08 80.01 0)
		(effects
			(font
				(size 1.524 1.524)
			)
			(justify left bottom)
		)
		(uuid "31f06715-6c31-4dc5-9602-8f583fcde631")
	)
	(text "Termination:\n\n40.2Ω series resistors (R9-R31) already placed on all DQ/DQS lines - these are source termination per Zynq UG933.\n80.6Ω differential termination (R33, R34) at the far end of the CK differential pair. This is the only P-to-N termination, matching ZC702 reference.\nR32 (4.7kΩ) pull-up on RESET# to +1V35 - correct.\nZQ calibration: R3 (240Ω 1%) on U2, R7 (240Ω 1%) on U4, both to GND - correct.\n\nStackup recommendation: For 40Ω SE / 80Ω diff on a 4-layer board, target ~4.5 mil trace width on 4 mil dielectric (FR4, εr ≈ 4.2) over solid ground plane. Use field solver for exact geometry.\nLength matching budget:\n\nDQ to DQS within byte lane: ±25 mil (±3.7 ps)\nCK to address/command group: ±50 mil (±7.4 ps)\nCK P-to-N intra-pair: ±5 mil (±0.75 ps)\nDQS P-to-N intra-pair: ±5 mil (±0.75 ps)"
		(exclude_from_sim no)
		(at 13.716 267.97 0)
		(effects
			(font
				(size 1.524 1.524)
			)
			(justify left)
		)
		(uuid "58ed3f5e-dc60-490f-b444-2175f20d2f4f")
	)
	(text "RECOMMENDED: Fly-by and \npoint-to-point routing is\nrecommended for optimal \nmemory performance"
		(exclude_from_sim no)
		(at 248.666 192.278 0)
		(effects
			(font
				(size 1.524 1.524)
			)
			(justify left bottom)
		)
		(uuid "6b8fc068-5f8d-42c9-afb9-2ba32452eda5")
	)
	(text "Differential termination at end / first break\nThis is the only P-to-N termination in ZC702 DDR3"
		(exclude_from_sim no)
		(at 190.754 74.93 0)
		(effects
			(font
				(size 1.524 1.524)
			)
			(justify left bottom)
		)
		(uuid "7770fc6c-1b4c-408c-afa6-837534fa4674")
	)
